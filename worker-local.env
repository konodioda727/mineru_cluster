MINERU_SERVER_ROLE=worker
MINERU_SERVER_PORT=50052

MINERU_SERVER_WORKER_PROCESSES=3
# REQUEST_CONCURRENCY intentionally omitted — defaults to WORKER_PROCESSES automatically
MINERU_SERVER_LOG_MODE=concise

MINERU_SERVER_MAX_WORKERS=1
MINERU_SERVER_CHUNK_SIZE=
MINERU_SERVER_BACKEND=pipeline
MINERU_SERVER_METHOD=auto
MINERU_SERVER_DEVICE=mps

MINERU_SERVER_FORMULA_ENABLE=false
MINERU_SERVER_TABLE_ENABLE=true
MINERU_SERVER_TABLE_MERGE_ENABLE=true

MINERU_SERVER_MAX_MESSAGE_BYTES=536870912
MINERU_SERVER_GRPC_WORKERS=4
MINERU_SERVER_KEEP_TEMP_DIR=true

MINERU_SERVER_KEEPALIVE_TIME_MS=120000
MINERU_SERVER_KEEPALIVE_TIMEOUT_MS=60000
MINERU_SERVER_KEEPALIVE_PERMIT_WITHOUT_CALLS=true
MINERU_SERVER_HTTP2_MAX_PINGS_WITHOUT_DATA=0
MINERU_SERVER_HTTP2_MIN_PING_INTERVAL_WITHOUT_DATA_MS=60000
MINERU_SERVER_HTTP2_MAX_PING_STRIKES=0
MINERU_SERVER_MAX_CONNECTION_IDLE_MS=1800000
MINERU_SERVER_MAX_CONNECTION_AGE_MS=7200000
MINERU_SERVER_MAX_CONNECTION_AGE_GRACE_MS=300000

MINERU_VIRTUAL_VRAM_SIZE=48
MINERU_PROCESSING_WINDOW_SIZE=300
MINERU_MODEL_SOURCE=modelscope
MINERU_SERVER_MAX_WORKER_MEMORY_GB=20